{
  "name": "gestion-documental-uts",
  "version": "1.0.0",
  "description": "Monorepo — Aplicación web con IA para la gestión documental en Mipymes de Bucaramanga",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start:backend": "npm run start --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "node backend/server.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
